@page "/book/create"
@model webapi.Components.Pages.Books.CreateModel

@{
    ViewData["Title"] = "Create Book";
    Layout = "../_Layout";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-6 offset-md-3">
            <h1>Create New Book</h1>
            <hr>
            
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger" role="alert">
                    <strong>Validation Error!</strong>
                    <ul>
                        @foreach (var modelState in ViewData.ModelState.Values)
                        {
                            @foreach (var error in modelState.Errors)
                            {
                                <li>@error.ErrorMessage</li>
                            }
                        }
                    </ul>
                </div>
            }
            
            <form method="post">
                @Html.AntiForgeryToken()
                
                <div class="mb-3">
                    <label for="bookTitle" class="form-label">Book Title *</label>
                    <input type="text" class="form-control" id="bookTitle" name="bookTitle" required>
                    <small class="text-muted">Required field</small>
                </div>
                
                <div class="mb-3">
                    <label for="authorName" class="form-label">Author Name *</label>
                    <input type="text" class="form-control" id="authorName" name="authorName" required>
                    <small class="text-muted">Required field</small>
                </div>
                
                <div class="mb-3">
                    <label for="bookDescription" class="form-label">Description</label>
                    <textarea class="form-control" id="bookDescription" name="bookDescription" rows="4"></textarea>
                </div>
                
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-success">Create</button>
                    <a href="/book" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
